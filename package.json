{
  "name": "graphnote",
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "lint": "biome lint src/",
    "format": "biome format --write src/",
    "format:check": "biome format src/"
  },
  "dependencies": {
    "@kjmkznr/egrph-wasm": "^0.4.0",
    "cytoscape": "^3.33.2",
    "dompurify": "3.4.0",
    "marked": "^18.0.1"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.13",
    "@types/dompurify": "^3.0.5",
    "fake-indexeddb": "^6.2.5",
    "typescript": "^6.0.3",
    "vite": "8.0.8",
    "vite-plugin-wasm": "^3.4.1",
    "vitest": "^4.1.4"
  }
}
